# Smart Cropping Configuration
# Add these to your .env file

# Enable/disable smart cropping features
# Features: blur background, stacking mode, smooth transitions
# Default: true
ENABLE_SMART_CROPPING=true

# Note: Smart cropping requires these dependencies:
# pip install ultralytics opencv-python moviepy numpy

# The following features are automatically enabled when ENABLE_SMART_CROPPING=true:
#
# 1. Blur Background Letterbox (0 people or wide scenes)
#    - Uses blurred frame instead of black bars
#
# 2. Smart Tracking (1 person)
#    - Auto-tracks face or person
#
# 3. Stacking Mode (2 people)
#    - 50:50 split screen for conversations
#
# 4. Wide Shot → Stacking (3+ people)
#    - Shows wide shot (2s) then transitions to stacking (0.5s crossfade)
#    - Focuses on 2 main subjects (largest faces)

# To disable smart cropping and use legacy crop behavior:
# ENABLE_SMART_CROPPING=false
